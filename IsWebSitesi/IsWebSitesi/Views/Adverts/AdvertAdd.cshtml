@model EntityLayer.Concrete.Advert
@{
    ViewData["Title"] = "AdvertAdd";
    Layout = "~/Views/Shared/EmployerLayout.cshtml";
}

<br /><br /><br /><br />
<h1>Yeni İlan Ekle</h1>
<br />
@using (Html.BeginForm("AdvertAdd", "Adverts", FormMethod.Post))
{ 
    @Html.Label("Departman")
    @Html.TextBoxFor(x=>x.Department,new { @class = "form-control" } )
    @Html.ValidationMessageFor(x=>x.Department)
    <br />
     @Html.Label("Çalışma Şekli")
    @Html.TextBoxFor(x=>x.JobType,new { @class = "form-control" } )
    @Html.ValidationMessageFor(x=>x.JobType)
    <br />
     @Html.Label("Açıklama")
    @Html.TextBoxFor(x=>x.Description,new { @class = "form-control" } )
    @Html.ValidationMessageFor(x=>x.Description)
    <br />
     @Html.Label("Gereklilikler")
    @Html.TextBoxFor(x=>x.Required,new { @class = "form-control" } )
    @Html.ValidationMessageFor(x=>x.Required)
    <br />
     @Html.Label("Deneyim")
    @Html.TextBoxFor(x=>x.Experience,new { @class = "form-control" } )
    @Html.ValidationMessageFor(x=>x.Experience)
    <br />
     @Html.Label("Son Başvuru Tarihi")
    @Html.TextBoxFor(x=>x.ApplicationDeadline,new { @class = "form-control" } )
    <br />
    <button class="btn btn-secondary">Ekle</button>





}