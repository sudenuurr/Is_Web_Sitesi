@model IEnumerable<EntityLayer.Concrete.Advert>


@foreach (var item in Model)
{


    <div class="single-job-items mb-30">
        <div class="job-items">
            <div class="company-img">
                <a href="#"><img src=@item.Company.ImageUrl alt=""></a>
            </div>
            <div class="job-tittle job-tittle2">
                <a href="#">
                    <h4>@item.Department</h4>
                </a>
                <ul>
                    <li>@item.Company.Name</li>
                </ul>
            </div>
        </div>
        <div class="items-link items-link2 f-right">
            <a href="/Adverts/AdvertsDetail/@item.AdvertID">@item.JobType</a>
            <span>@item.PostedDate.ToShortDateString()</span>
        </div>
    </div>}